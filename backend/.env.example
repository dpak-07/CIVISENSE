PORT=5000
AI_SERVICE_BASE_URL=http://localhost:8000
MONGO_URI=mongodb://localhost:27017/civisense
NODE_ENV=development
JWT_ACCESS_SECRET=change_me_access_secret
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
CORS_ORIGIN=http://localhost:5173,http://localhost:8081,http://127.0.0.1:8081
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key
AWS_BUCKET_NAME=your_bucket_name
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@example.com
SMTP_PASS=your_app_password
SMTP_FROM="CiviSense Contact <your_email@example.com>"
CONTACT_TO_EMAIL=project_owner@example.com
MISUSE_REPORT_THRESHOLD=3
PRIORITY_ESCALATE_INTERVAL_MS=1800000
PRIORITY_ESCALATE_UNPROCESSED_DAY1=1
PRIORITY_ESCALATE_UNPROCESSED_DAY2=2
PRIORITY_ESCALATE_INPROGRESS_DAY1=3
PRIORITY_ESCALATE_INPROGRESS_DAY2=5
