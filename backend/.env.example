### Shared CiviSense Environment (Backend + AI Service)
### Backend reads this file directly.
### AI service also reads this file by default via CIVISENSE_ENV_FILE or automatic fallback.

### Backend runtime
PORT=5000
NODE_ENV=development

### Shared Mongo
MONGO_URI=mongodb://localhost:27017/civisense

### Auth / tokens
JWT_ACCESS_SECRET=change_me_access_secret
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

### CORS + cookies
CORS_ORIGIN=http://localhost:5173,http://localhost:8081,http://127.0.0.1:8081
CORS_CREDENTIALS=true
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax
COOKIE_DOMAIN=

### Feature flags
ALLOW_DEMO_LOGIN=false

### Rate limit
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200

### AWS / S3
AWS_REGION=ap-south-1
AWS_BUCKET_NAME=your_bucket_name
# Optional: leave empty to use IAM role/default AWS credential chain.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

### SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@example.com
SMTP_PASS=your_app_password
SMTP_FROM="CiviSense Contact <your_email@example.com>"
CONTACT_TO_EMAIL=project_owner@example.com

### AI service
APP_NAME=CiviSense AI Decision Engine
ENVIRONMENT=production
LOG_LEVEL=INFO
MONGO_DB_NAME=civisense
MONGO_COMPLAINTS_COLLECTION=complaints
MONGO_SENSITIVE_LOCATIONS_COLLECTION=sensitive_locations
MONGO_AI_BLACKLIST_COLLECTION=ai_blacklist
MONGO_SERVER_SELECTION_TIMEOUT_MS=5000
MONGO_CONNECT_TIMEOUT_MS=10000
MONGO_ALLOW_STANDALONE_FALLBACK=true
YOLO_MODEL_NAME=yolov8n.pt
YOLO_CONFIDENCE_THRESHOLD=0.25
YOLO_IMAGE_SIZE=640
YOLO_MAX_IMAGE_DIMENSION=1024
YOLO_MIN_CONFIDENCE_FOR_SEVERITY=0.4
CPU_THREADS=2
IMAGE_DOWNLOAD_TIMEOUT_SECONDS=15
IMAGE_MAX_BYTES=10485760
SCHOOL_RADIUS_METERS=2000
DUPLICATE_SIMILARITY_THRESHOLD=0.92
DUPLICATE_LOOKBACK_DAYS=7
DUPLICATE_COMPARE_LIMIT=50
USER_MISMATCH_BLACKLIST_THRESHOLD=3
RETRY_INTERVAL_SECONDS=60
MAX_RETRY_ATTEMPTS=3
RETRY_BATCH_SIZE=25

### AI monitoring endpoint protection
AI_MONITOR_API_KEY=
