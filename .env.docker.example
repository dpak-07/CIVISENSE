# Copy this file to .env on the EC2 host, then fill the blank values.

# Public web entrypoint.
HTTP_PORT=80
VITE_API_BASE_URL=/api
CORS_ORIGIN=http://localhost

# Shared database.
MONGO_DB_NAME=civisense

# Backend runtime.
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200
MISUSE_REPORT_THRESHOLD=3
PRIORITY_ESCALATE_INTERVAL_MS=1800000
PRIORITY_ESCALATE_UNPROCESSED_DAY1=1
PRIORITY_ESCALATE_UNPROCESSED_DAY2=2
PRIORITY_ESCALATE_INPROGRESS_DAY1=3
PRIORITY_ESCALATE_INPROGRESS_DAY2=5

# Required by the current backend upload code.
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=<rotated-aws-access-key-id>
AWS_SECRET_ACCESS_KEY=<rotated-aws-secret-access-key>
AWS_BUCKET_NAME=civisense
AWS_S3_ENDPOINT_URL=https://s3.ap-south-1.amazonaws.com

# Optional email/contact settings.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=deepakofficial0103@gmail.com
SMTP_PASS=<rotated-gmail-app-password>
SMTP_FROM="CiviSense Contact <deepakofficial0103@gmail.com>"
CONTACT_TO_EMAIL=deepakofficial0103@gmail.com

# AI service tuning.
APP_NAME=CiviSense AI Decision Engine
LOG_LEVEL=INFO
MONGO_COMPLAINTS_COLLECTION=complaints
MONGO_SENSITIVE_LOCATIONS_COLLECTION=sensitive_locations
MONGO_AI_BLACKLIST_COLLECTION=ai_blacklist
MONGO_SERVER_SELECTION_TIMEOUT_MS=5000
MONGO_CONNECT_TIMEOUT_MS=10000
YOLO_MODEL_NAME=yolov8n.pt
YOLO_CONFIDENCE_THRESHOLD=0.25
YOLO_IMAGE_SIZE=640
YOLO_MAX_IMAGE_DIMENSION=1024
YOLO_MIN_CONFIDENCE_FOR_SEVERITY=0.4
CPU_THREADS=2
HF_CAPTION_MODEL_NAME=Salesforce/blip-image-captioning-base
HF_CAPTION_MAX_NEW_TOKENS=32
HF_CAPTION_NUM_BEAMS=3
HF_CLIP_MODEL_NAME=openai/clip-vit-base-patch32
HF_CLIP_SCORE_WEIGHT=3.0
HF_CLIP_MIN_CONFIDENCE=0.28
CIVIC_CLASSIFIER_ENABLED=true
CIVIC_CLASSIFIER_MODEL_PATH=
CIVIC_CLASSIFIER_STATE_FILE=training_data/train_state.json
CIVIC_CLASSIFIER_IMAGE_SIZE=224
CIVIC_CLASSIFIER_SCORE_WEIGHT=4.2
CIVIC_CLASSIFIER_MIN_CONFIDENCE=0.5
REASON_NLP_ENABLED=true
HF_REASON_MODEL_NAME=google/flan-t5-small
HF_REASON_MAX_NEW_TOKENS=72
CATEGORY_VALIDATION_REVIEW_CONFIDENCE=0.6
IMAGE_DOWNLOAD_TIMEOUT_SECONDS=15
IMAGE_MAX_BYTES=10485760
SCHOOL_RADIUS_METERS=2000
HOSPITAL_RADIUS_METERS=1400
TRANSIT_RADIUS_METERS=1200
GOVERNMENT_RADIUS_METERS=1000
DUPLICATE_SIMILARITY_THRESHOLD=0.92
DUPLICATE_LOOKBACK_DAYS=7
DUPLICATE_COMPARE_LIMIT=50
USER_MISMATCH_BLACKLIST_THRESHOLD=3
RETRY_INTERVAL_SECONDS=60
MAX_RETRY_ATTEMPTS=3
RETRY_BATCH_SIZE=25
AI_OUTPUT_PREFIX=ai-outputs
AI_MAX_ANNOTATIONS=6
AI_MODEL_DISCLAIMER=AI result generated by CiviSense models and reviewed through service rules.
