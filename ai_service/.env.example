APP_NAME=CiviSense AI Decision Engine
ENVIRONMENT=production
LOG_LEVEL=INFO

MONGO_URI=mongodb://localhost:27017/?replicaSet=rs0
MONGO_DB_NAME=civisense
MONGO_COMPLAINTS_COLLECTION=complaints
MONGO_SENSITIVE_LOCATIONS_COLLECTION=sensitive_locations
MONGO_AI_BLACKLIST_COLLECTION=ai_blacklist
MONGO_SERVER_SELECTION_TIMEOUT_MS=5000
MONGO_CONNECT_TIMEOUT_MS=10000
MONGO_ALLOW_STANDALONE_FALLBACK=true

YOLO_MODEL_NAME=yolov8n.pt
YOLO_CONFIDENCE_THRESHOLD=0.25
YOLO_IMAGE_SIZE=640
YOLO_MAX_IMAGE_DIMENSION=1024
YOLO_MIN_CONFIDENCE_FOR_SEVERITY=0.4
CPU_THREADS=2
HF_CAPTION_MODEL_NAME=Salesforce/blip-image-captioning-base
HF_CAPTION_MAX_NEW_TOKENS=32
HF_CAPTION_NUM_BEAMS=3
HF_CLIP_MODEL_NAME=openai/clip-vit-base-patch32
HF_CLIP_SCORE_WEIGHT=3.0
HF_CLIP_MIN_CONFIDENCE=0.28
REASON_NLP_ENABLED=true
HF_REASON_MODEL_NAME=google/flan-t5-small
HF_REASON_MAX_NEW_TOKENS=72
CATEGORY_VALIDATION_REVIEW_CONFIDENCE=0.6

IMAGE_DOWNLOAD_TIMEOUT_SECONDS=15
IMAGE_MAX_BYTES=10485760

SCHOOL_RADIUS_METERS=2000
HOSPITAL_RADIUS_METERS=1400
TRANSIT_RADIUS_METERS=1200
GOVERNMENT_RADIUS_METERS=1000
DUPLICATE_SIMILARITY_THRESHOLD=0.92
DUPLICATE_LOOKBACK_DAYS=7
DUPLICATE_COMPARE_LIMIT=50
USER_MISMATCH_BLACKLIST_THRESHOLD=3
RETRY_INTERVAL_SECONDS=60
MAX_RETRY_ATTEMPTS=3
RETRY_BATCH_SIZE=25

AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET_NAME=
AWS_S3_ENDPOINT_URL=https://s3.ap-south-1.amazonaws.com

AI_OUTPUT_PREFIX=ai-outputs
AI_MAX_ANNOTATIONS=6
AI_MODEL_DISCLAIMER=Note: This AI result is generated using a stock pre-trained model and will be fine-tuned in later versions.
